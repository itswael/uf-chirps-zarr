# CHIRPS Data Pipeline Configuration
# Copy this file to .env and fill in your values

# Email Notification Configuration
# Set to "true" to enable email notifications
CHIRPS_EMAIL_ENABLED=false

# SMTP Server Configuration
# For Gmail: smtp.gmail.com with port 587
# For Outlook: smtp.office365.com with port 587
CHIRPS_SMTP_HOST=smtp.gmail.com
CHIRPS_SMTP_PORT=587
CHIRPS_SMTP_USE_TLS=true

# SMTP Authentication
# For Gmail, use your email and an app-specific password
# For Outlook/Office365, use your email and password
CHIRPS_SMTP_USERNAME=your-email@example.com
CHIRPS_SMTP_PASSWORD=your-app-password-here

# Email Sender
# The "From" address that will appear in sent emails
CHIRPS_EMAIL_FROM=your-email@example.com

# Email Recipients File
# Path to file containing recipient email addresses (one per line)
CHIRPS_EMAIL_RECIPIENTS_FILE=config/email_recipients.txt

# Data Directories (optional - defaults shown)
# CHIRPS_BASE_DIR=.
# CHIRPS_RAW_DIR=data/raw
# CHIRPS_INTERIM_DIR=data/interim
# CHIRPS_ZARR_DIR=data/zarr

# Download Configuration (optional)
# CHIRPS_DOWNLOAD_CONCURRENCY=5
# CHIRPS_TIMEOUT_SECONDS=30
# CHIRPS_MAX_RETRIES=3
# CHIRPS_RETRY_DELAY_SECONDS=5

# Bootstrap Configuration (optional)
# CHIRPS_BOOTSTRAP_START_DATE=1981-01-01
# CHIRPS_BOOTSTRAP_END_DATE=2023-12-31

# Incremental Configuration (optional)
# Set max days to process per incremental run (None = unlimited, up to today)
# CHIRPS_INCREMENTAL_MAX_DAYS_PER_RUN=30

# Zarr Configuration (optional)
# CHIRPS_ZARR_TIME_CHUNK_SIZE=30
# CHIRPS_ZARR_LAT_CHUNK_SIZE=250
# CHIRPS_ZARR_LON_CHUNK_SIZE=250
